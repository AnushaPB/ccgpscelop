# get all het and coords files
rsync -avz --include="*/" --include="*.het" --include="*coords*" --exclude="*" hgdownload.soe.ucsc.edu::ccgp/ccgp/ .

rsync -avzn --include="*/" --include="*.het" --include="*coords*" --exclude="*" hgdownload.soe.ucsc.edu::ccgp/ .

# extract files from folders
find . -type f \( -name "*.het" -o -name "*coords*" \) -exec mv {} . \;

# delete empty folders
find . -type d -empty -delete


# Create list of species folders
rsync -avzn --include="*/" --exclude="*" --list-only hgdownload.soe.ucsc.edu::ccgp/CCGP-module/ | \
# Extract the species folders
grep '/CCGP' | \
awk '{print $5}' | \
# Remove the /CCGP from the end of the folder name
sed 's|/CCGP||' | \
# Exclude the weird folders
grep -v -e 'cali_small' -e 'no_filter' -e 'old' -e 'original' -e '.bak' -e 'extended' > CCGP-module_species

for species in `cat CCGP-module_species`
do 
  rsync -avz \
 --exclude="*" \
  --include="*/" \
  --include="*pi*" \
  --include="*coords*" \
  hgdownload.soe.ucsc.edu::ccgp/CCGP-module/$species/CCGP/ .
done


for species in `cat CCGP-module_species`; do echo "rsync -avP hgdownload.soe.ucsc.edu::ccgp/CCGP-module/$species/CCGP/*_filtered* ./$species/" >> dist_file_dl; done # will also copy the roh files

for species in `cat CCGP-module_species`; do echo "rsync -avP hgdownload.soe.ucsc.edu::ccgp/CCGP-module/$species/CCGP/*_annotated_pruned_0.6* ./$species/" >> ldpruned_file_dl; done # this will also copy dist files for LD-pruned datasets
for species in `cat CCGP-module_species`; do echo "rsync -avP hgdownload.soe.ucsc.edu::ccgp/CCGP-module/$species/CCGP/*_annotated.vcf.gz ./$species/" >> vcf_file_dl; done
for species in `cat CCGP-module_species`; do echo "rsync -avP --exclude "*filtered*" hgdownload.soe.ucsc.edu::ccgp/$species/QC/ ./$species/QC" >> qc_dl; done

# Make directories
for species in `cat CCGP-module_species`; do `mkdir $species`; `mkdir $species/QC`; done # will skip species for which dir already exists

# Only relevant file (coords) and puts in main species dir (i.e., not QC folder)
for species in `cat CCGP-module_species`; do echo "rsync -avP hgdownload.soe.ucsc.edu::ccgp/$species/QC/*coords.txt ./$species/" >> coords_dl; done

# Can also copy coords file into the main dir like so:
ls */QC/*coords.txt >> coords
cat coords | while read line; do echo $"cp "${line} >> coords; done # add copy command to beginning of each line
cat coords | while read line; do echo ${line}$" ../" >> coords; done # add move up one level to end of each line
bash coords

# QC EXCLUDING filtered vcf (i.e., only pruned vcf, etc.) in its own dir called QC per species
for species in `cat CCGP-module_species`; do `mkdir $species`; `mkdir $species/QC`; echo "rsync -avP --exclude "*filtered*" hgdownload.soe.ucsc.edu::ccgp/$species/QC/ ./$species/QC/" >> qc_dl; done
for species in `cat CCGP-module_species`; do echo "rsync -avP --exclude "*filtered*" hgdownload.soe.ucsc.edu::ccgp/$species/QC/ ./$species/QC/" >> qc_dl; done

# Run the code!
bash qc_dl # excludes filtered vcf
bash dist_file_dl # downloads dist, dist.id, and roh files
bash ldpruned_file_dl # downloads annotated pruned 0.6 vcf, dist, and dist.id files
bash coords_dl # downloads coords file to main species directory (rather than QC dir)
bash vcf_file_dl # downloads full (unpruned) annotated vcf; LARGE FILE!!!